# Nano Claude v2 — NO API KEY NEEDED
# =====================================
# The LLM runs entirely in the browser.
# Only the Neon DB connection is optional.

# Neon PostgreSQL (optional — falls back to memory if not set)
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Port (default: 3000)
PORT=3000
